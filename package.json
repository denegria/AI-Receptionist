{
  "name": "ai-receptionist",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "dev": "nodemon --exec npx ts-node src/server.ts",
    "build": "npx tsc && npx shx mkdir -p dist/db/migrations && npx shx cp -r src/db/migrations/* dist/db/migrations/ && npx shx cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/server.js",
    "seed:golden-tenant": "ts-node src/scripts/seed-golden-tenant.ts",
    "test:synthetic:single": "ts-node src/scripts/synthetic-load-test.ts --mode single --concurrency 3 --scenario hibye",
    "test:synthetic:matrix": "ts-node src/scripts/synthetic-load-test.ts --mode matrix --tenants 5 --concurrency 2 --scenario hibye",
    "twilio:preflight": "ts-node src/scripts/twilio-preflight.ts",
    "twilio:alerts": "ts-node src/scripts/twilio-alert-check.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/express-ws": "^3.0.6",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "shx": "^0.4.0",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@deepgram/sdk": "^4.11.3",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@types/express-rate-limit": "^6.0.2",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-ws": "^5.0.2",
    "googleapis": "^171.4.0",
    "isomorphic-fetch": "^3.0.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0",
    "twilio": "^5.12.2"
  }
}
